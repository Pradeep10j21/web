  --b: 1px;
  --b2: 0.5px;              /* border thickness */
  --r: 1px;             /* radius */
  --top: #fff;           /* top border color */
  --side: #fff;          /* side start color */

  border-radius: var(--r);

  background:
    /* TOP border (solid white) */
    linear-gradient(var(--top), var(--top)) top / 100% var(--b) no-repeat,

    /* LEFT border (white -> transparent downward) */
